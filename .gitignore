# Root .gitignore for Merkle Task Management Framework

# OS specific
.DS_Store
Thumbs.db
*.swp
*.bak

# IDEs
.vscode/
.idea/
.zed/
.nova/
.fleet/

# Dependencies
node_modules/
vendor/
output/code/node_modules/
output/code/vendor/

# Environment & Secrets
.env
.env.*
output/code/.env
output/code/.env.*
*.key

# Laravel specific (output/code)
output/code/storage/*.key
output/code/storage/app/public/*
output/code/storage/framework/cache/data/*
output/code/storage/framework/cache/laravel-excel/*
output/code/storage/framework/sessions/*
output/code/storage/framework/views/*
output/code/storage/logs/*.log
output/code/storage/pail/
output/code/public/build/
output/code/public/hot/
output/code/public/storage
output/code/.phpunit.result.cache
output/code/.phpunit.cache/
output/code/database/database.sqlite
output/code/bootstrap/cache/*.php
output/code/vite.log

# Terraform specific (output/infra)
output/infra/.terraform/
output/infra/*.tfstate
output/infra/*.tfstate.*
output/infra/.terraform.lock.hcl
output/infra/*.tfvars
output/infra/*.tfvars.json
output/infra/*.tfplan

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files & Build artifacts
rewrite_tailwind.js
refactor_kanban.js
cleanup_kanban.js
remove_task_modal.js
update_script.js
.phpunit.result.cache
dist/
build/
